# Release signing credentials for assembleRelease.
#
# CookTrace shares one keystore with NutriTrace and LiftTrace — the
# whole "TraceApps" family signs from the same publisher identity.
# Pros: simpler key management, family-wide signature parity, future
# possibility of signature-shared permissions between apps. Cons:
# single point of failure if the keystore is lost (so back it up).
#
# Copy this file to `keystore.properties` (alongside this one) and
# fill in your own values. The real keystore.properties is gitignored
# and never committed.
#
# Without this file, assembleRelease falls back to debug signing —
# fine for local testing, NOT suitable for distribution.

# Path to the shared TraceApps keystore. Same file is used by
# nutritrace, cooktrace, and lifttrace — pointed at by each app's
# keystore.properties. Generated on 2026-05-02; backed up at
# ~/.android/nutritrace-release.keystore.bak.<date> as the
# pre-rename copy.
storeFile=/home/papa/.android/traceapps-release.keystore

# Password set when generating the keystore.
storePassword=CHANGE_ME

# Alias for the key inside the keystore. The shared TraceApps keystore
# uses alias=nutritrace for historical reasons (it was created when
# NutriTrace was the only Android app). Leave as-is — changing the
# alias requires keytool -changealias and re-signing every existing
# install.
keyAlias=nutritrace

# Password for the key (often the same as storePassword).
keyPassword=CHANGE_ME

# ──────────────────────────────────────────────────────────────────────
# IF you ever need to mint a new TraceApps keystore from scratch
# (don't unless the old one is compromised — once published apps are
# signed with a key, that's the signing identity forever):
#
#   keytool -genkeypair -v \
#     -keystore ~/.android/traceapps-release.keystore \
#     -alias traceapps \
#     -keyalg RSA -keysize 4096 -validity 36500
#
# Then update keystore.properties in each TraceApp pointing at the
# new path + passwords + alias. Note: this only works for apps that
# have never been published. Any app already on Play Store or with
# users running side-loaded APKs is locked to its existing key.
